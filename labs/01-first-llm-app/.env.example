# Copy to .env and pick a backend. .env is gitignored.
#
# MODEL_BACKEND options:
#   ollama  — local, $0, private. Best on Apple Silicon (M-series). Default.
#   groq    — free hosted tier, very fast. Best for Intel/older Macs & locked-down laptops.
#   openai  — paid, cheap at lab volume.

MODEL_BACKEND=ollama

# For hosted backends, set the matching key (get a free one from the provider):
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# Optional overrides:
# MODEL=llama3.1:8b          # e.g. llama3.2:3b on a slower CPU; llama-3.1-8b-instant on Groq
# OPENAI_BASE_URL=...         # point at any other OpenAI-compatible endpoint
