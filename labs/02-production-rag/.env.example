# Copy to .env and choose backends. .env is gitignored. See labs/model-backends.md.

# --- Chat (generates the answer): ollama | groq | openai ---
MODEL_BACKEND=ollama
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# MODEL=llama3.1:8b

# --- Embeddings (powers retrieval): ollama | openai ---
# Groq is chat-only, so embeddings stay on Ollama (or OpenAI) even if chat is Groq.
EMBED_BACKEND=ollama
# EMBED_MODEL=nomic-embed-text          # ollama default
# EMBED_MODEL=text-embedding-3-small    # openai default
