# Copy to .env and choose a chat backend. .env is gitignored. See labs/model-backends.md.
#
# Agents rely on the model's tool-routing, so prefer a capable model:
#   ollama with llama3.1:8b, or a hosted backend (Groq / OpenAI). Small models
#   (3B) route unreliably.

MODEL_BACKEND=ollama
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# MODEL=llama3.1:8b
